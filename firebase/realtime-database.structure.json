{
  "metadata": {
    "project_name": "Conexao Azul",
    "database_model": "firebase-realtime-database",
    "version": 1,
    "description": "Estrutura base para monitoramento de qualidade da agua com ESP32, Django e Firebase."
  },
  "monitoring_config": {
    "thresholds": {
      "temperature_c": {
        "normal_min": 20,
        "normal_max": 30,
        "alert_min": 15,
        "alert_max": 35
      },
      "turbidity_ntu": {
        "normal_max": 5,
        "alert_max": 25
      },
      "ph": {
        "normal_min": 6.5,
        "normal_max": 8.5,
        "alert_min": 6.0,
        "alert_max": 9.0
      },
      "water_level_cm": {
        "normal_min": 40,
        "normal_max": 180
      }
    },
    "sampling": {
      "default_interval_seconds": 15,
      "timezone": "America/Bahia"
    }
  },
  "devices": {
