          "enabled": true,
          "pin": 4,
          "type": "DS18B20"
        },
        "turbidity": {
          "enabled": true,
          "pin": 34,
          "type": "analog"
        },
        "ph": {
          "enabled": true,
          "pin": 32,
          "type": "analog"
        },
        "ultrasonic": {
          "enabled": true,
          "trig_pin": 5,
          "echo_pin": 18,
